{
  "uid": "argus-logs",
  "title": "argus Logs",
  "tags": ["argus", "logs"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "argus-loki" },
        "query": {
          "label": "service",
          "refId": "StandardVariableQuery",
          "stream": "{job=\"docker\"}",
          "type": 1
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "hide": 0
      },
      {
        "name": "level",
        "label": "Level",
        "type": "custom",
        "query": "error,warn,info",
        "current": { "value": ["error", "warn", "info"], "text": ["error", "warn", "info"] },
        "options": [
          { "value": "error", "text": "error", "selected": true },
          { "value": "warn", "text": "warn", "selected": true },
          { "value": "info", "text": "info", "selected": true }
        ],
        "multi": true,
        "includeAll": false,
        "hide": 0
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "query": "",
        "current": { "value": "", "text": "" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log volume by level",
      "datasource": { "type": "loki", "uid": "argus-loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warn" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "info" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "argus-loki" },
          "expr": "sum by (level) (count_over_time({job=\"docker\", service=~\"$service\", level=~\"$level\"} [$__interval]))",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Log stream",
      "datasource": { "type": "loki", "uid": "argus-loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 8 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "argus-loki" },
          "expr": "{job=\"docker\", service=~\"$service\", level=~\"$level\"} | json |~ \"$search\""
        }
      ]
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Error count by service (range)",
      "datasource": { "type": "loki", "uid": "argus-loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "argus-loki" },
          "expr": "sum by (service) (count_over_time({job=\"docker\", service=~\"$service\", level=\"error\"} [$__range]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Warn count by service (range)",
      "datasource": { "type": "loki", "uid": "argus-loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] } }, "overrides": [] },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "argus-loki" },
          "expr": "sum by (service) (count_over_time({job=\"docker\", service=~\"$service\", level=\"warn\"} [$__range]))",
          "legendFormat": "{{service}}"
        }
      ]
    }
  ]
}
