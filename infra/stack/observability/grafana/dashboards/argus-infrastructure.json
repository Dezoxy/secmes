{
  "uid": "argus-infrastructure",
  "title": "argus Infrastructure",
  "tags": ["argus", "infra"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "PostgreSQL",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Active connections",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "pg_stat_activity_count{datname=\"argus\"}",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Cache hit ratio",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.90 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "sum(pg_stat_database_blks_hit{datname=\"argus\"}) / (sum(pg_stat_database_blks_hit{datname=\"argus\"}) + sum(pg_stat_database_blks_read{datname=\"argus\"}))",
          "legendFormat": "cache hit"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Commits & rollbacks per second",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "ops", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "rate(pg_stat_database_xact_commit{datname=\"argus\"}[5m])",
          "legendFormat": "commits/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"argus\"}[5m])",
          "legendFormat": "rollbacks/s"
        }
      ]
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Dead tuples by table (bloat signal)",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "topk(10, pg_stat_user_tables_n_dead_tup)",
          "legendFormat": "{{relname}}"
        }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "Redis",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Memory used",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used"
        }
      ]
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "Cache hit ratio",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.80 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "redis_keyspace_hits_total / (redis_keyspace_hits_total + redis_keyspace_misses_total)",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Commands per second",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "ops", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "rate(redis_commands_processed_total[5m])",
          "legendFormat": "cmds/s"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Connected clients",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "redis_connected_clients",
          "legendFormat": "clients"
        }
      ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "Node.js process",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Heap used vs heap total",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "argus_api_nodejs_heap_size_used_bytes",
          "legendFormat": "heap used"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "argus_api_nodejs_heap_size_total_bytes",
          "legendFormat": "heap total"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Event loop lag p50 / p99",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(argus_api_nodejs_eventloop_lag_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(argus_api_nodejs_eventloop_lag_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Active handles & requests",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "argus_api_nodejs_active_handles_total",
          "legendFormat": "handles"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "argus_api_nodejs_active_requests_total",
          "legendFormat": "requests"
        }
      ]
    }
  ]
}
