{
  "uid": "argus-security",
  "title": "argus Security",
  "tags": ["argus", "security"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Auth attempt rate by result & method (1m)",
      "description": "Real-time authentication attempt rate from Prometheus. A spike in failure/webauthn or failure/breakglass is an active attack signal.",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "sum by (result, method) (rate(argus_auth_attempts_total[1m]))",
          "legendFormat": "{{result}}/{{method}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "bargauge",
      "title": "Failed auth attempts (range)",
      "datasource": { "type": "loki", "uid": "argus-loki" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "argus-loki" },
          "expr": "sum by (msg) (count_over_time({job=\"docker\", level=\"warn\"} | json | context=~\"WebAuthnService|SessionTokenService|BreakglassService\" [$__range]))",
          "legendFormat": "{{msg}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "WS auth failures",
      "datasource": { "type": "loki", "uid": "argus-loki" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "argus-loki" },
          "expr": "sum(count_over_time({job=\"docker\"} | json | msg=\"ws:auth_failed\" [$__range]))",
          "legendFormat": "auth failures"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "WS auth timeouts",
      "datasource": { "type": "loki", "uid": "argus-loki" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "argus-loki" },
          "expr": "sum(count_over_time({job=\"docker\"} | json | msg=\"ws:auth_timeout\" [$__range]))",
          "legendFormat": "auth timeouts"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "WS subscribe rate-limit hits",
      "datasource": { "type": "loki", "uid": "argus-loki" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "argus-loki" },
          "expr": "sum(count_over_time({job=\"docker\"} | json | msg=\"ws:subscribe_rate_limited\" [$__interval]))",
          "legendFormat": "rate-limited subscribes"
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Active WS sessions by tenantId (range)",
      "description": "tenantId values are opaque UUIDs. A large spike in one tenant could indicate automated abuse.",
      "datasource": { "type": "loki", "uid": "argus-loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "argus-loki" },
          "expr": "sum by (tenantId) (count_over_time({job=\"docker\"} | json | msg=\"ws:auth\" [$__range]))",
          "legendFormat": "{{tenantId}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Breakglass event stream",
      "description": "Any activity here warrants review. All values are internal IDs only — no content.",
      "datasource": { "type": "loki", "uid": "argus-loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "argus-loki" },
          "expr": "{job=\"docker\"} | json | context=\"BreakglassService\""
        }
      ]
    }
  ]
}
