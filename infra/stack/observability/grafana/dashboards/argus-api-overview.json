{
  "uid": "argus-api-overview",
  "title": "argus API overview",
  "tags": ["argus"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 2,
  "editable": false,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by status",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "sum(rate(argus_api_http_requests_total[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Server-error (5xx) ratio — SLO < 1% / 5%",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "sum(rate(argus_api_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(argus_api_http_requests_total[5m]))",
          "legendFormat": "5xx ratio"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request latency p50 / p95 / p99 — SLO p95 < 1s",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(argus_api_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(argus_api_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "exemplar": true
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(argus_api_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "API process — resident memory & CPU",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "argus_api_process_resident_memory_bytes",
          "legendFormat": "RSS (bytes)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "rate(argus_api_process_cpu_seconds_total[5m])",
          "legendFormat": "CPU (cores)"
        }
      ]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Recent error logs",
      "datasource": { "type": "loki", "uid": "argus-loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "argus-loki" },
          "expr": "{job=\"docker\", level=\"error\"} | json | line_format \"[{{.context}}] {{.msg}}\""
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Recent warn logs",
      "datasource": { "type": "loki", "uid": "argus-loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "argus-loki" },
          "expr": "{job=\"docker\", level=\"warn\"} | json | line_format \"[{{.context}}] {{.msg}}\""
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Active WebSocket connections",
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
          "expr": "argus_ws_connections_active",
          "legendFormat": "active WS connections"
        }
      ]
    }
  ]
}
