# argus production single-origin router.
#
# Plain HTTP on :8080 ONLY. TLS terminates at the Cloudflare edge; cloudflared dials this server over the
# internal Docker network, so Caddy never needs a public cert or :443. A non-privileged port lets Caddy run
# as a non-root user with all Linux capabilities dropped. Caddy is the single origin: it serves the PWA
# static build and reverse-proxies /api + /ws to the API. The Cloudflare tunnel ingress (dashboard-managed)
# points the public hostname at http://caddy:8080. See docs/threat-models/vm-ingress.md.
{
	# No public cert, no :443, no Let's Encrypt — the edge owns TLS.
	auto_https off
	# Admin API off: nothing on this host should reconfigure Caddy at runtime.
	admin off
	# Access log to stdout (collected by Docker). Caddy redacts Authorization + Cookie headers by default and
	# never logs bodies; on top of that we strip the ENTIRE query string from the logged URI — the OIDC
	# callback carries `?code=<auth-code>` and some API routes carry `?proof=`, both auth material (invariant
	# #2). The `filter` encoder's regexp filter replaces everything after `?`, so no query-borne credential
	# ever lands in Docker logs. Logs stay IDs/metadata + path only.
	log {
		output stdout
		format filter {
			wrap json
			fields {
				request>uri regexp "\?.*" "?[redacted]"
			}
		}
	}
}

# --- Grafana (observability dashboards, https://grafana.4rgus.com) — roadmap #47 ------------------------
# Admin surface: gated by Cloudflare Access at the edge (identity) + Grafana's own login; NEVER public. Caddy
# just forwards (Grafana speaks plain HTTP/1.1, no h2c). Prometheus + Alertmanager are NOT routed here — they
# stay internal-only, viewed through Grafana. GF_SERVER_ROOT_URL makes Grafana emit correct https URLs.
http://grafana.4rgus.com:8080 {
	reverse_proxy grafana:3000
}

# --- GlitchTip (error tracking, https://glitchtip.4rgus.com) — roadmap #48 Slice B -----------------------
# Admin surface: gated by Cloudflare Access at the edge (identity) + GlitchTip's own auth; NEVER public.
# No h2c — GlitchTip speaks plain HTTP/1.1 (Django/gunicorn). Internal-only; shares the VM failure domain.
http://glitchtip.4rgus.com:8080 {
	reverse_proxy glitchtip:8000
}

# --- App origin (PWA + /api + /ws) — catch-all :8080 for every other host (4rgus.com, health, direct IP) ---
:8080 {
	# Code-delivery hardening response headers (#43; the edge adds HSTS). Served HERE at the static origin so
	# the CSP applies to every response and `frame-ancestors` works (a <meta> CSP ignores it). The directive set
	# is derived from the PWA's resource graph — UPDATE it when the client adds an external origin; smoke-test
	# against the live app at arming (CSP violations surface in the browser console). SRI (sha384 integrity on
	# the built bundles via vite-plugin-sri3) + the published bundle-manifest.json are emitted at build time, and
	# service-worker pinning is the @revalidate/@immutable cache policy below — the #43 frontend-build slice is
	# now complete (docs/threat-models/code-delivery-integrity.md).
	header {
		# script-src is strict 'self' — no inline scripts (index.html only loads /src/main.tsx as a module) and
		# ts-mls is pure JS (no wasm-eval), so injected/foreign script can't run to read decrypted content or keys
		# (the core control). connect-src: same-origin REST+WS ('self' covers wss) and B2 presigned
		# upload/download. img data:/blob: = generated
		# avatars + decrypted attachment object URLs. style 'unsafe-inline' for React/Tailwind inline styles.
		# connect-src lists the same-origin WS origin (wss://4rgus.com) EXPLICITLY, not just 'self': only CSP
		# Level 3 browsers resolve 'self' to ws(s) schemes, so older ones would block the live socket (silent
		# delivery failure). A SPLIT deploy (VITE_API_URL/VITE_WS_URL on another host) must add that origin too.
		# B2 egress is PINNED to the single prod attachment bucket's virtual-host subdomain (CSP-1):
		# S3_FORCE_PATH_STYLE=false → every presigned URL is on
		# attachment-r8xq4m7z2p9n6k3v.s3.eu-central-003.backblazeb2.com. The old wildcard
		# `*.s3.eu-central-003.backblazeb2.com` + bare path-style `s3.eu-central-003.backblazeb2.com` host were
		# removed: a CSP source is host-only (it cannot restrict the path), so the bare host permitted a
		# path-style POST to ANY bucket in the shared region namespace — an attacker exfil egress. This host is
		# bound two ways: scripts/check-csp-connect-src.sh fails CI if it drifts from deploy.sh's
		# ATTACHMENT_BUCKET literal, and deploy.sh fails the deploy closed if the runtime S3_BUCKET (the bucket
		# the API actually presigns against) differs — together they guarantee this is the real presign host.
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' wss://4rgus.com https://attachment-r8xq4m7z2p9n6k3v.s3.eu-central-003.backblazeb2.com; worker-src 'self' blob:; manifest-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests"
		Permissions-Policy "accelerometer=(), autoplay=(), bluetooth=(), camera=(), display-capture=(), geolocation=(), gyroscope=(), hid=(), magnetometer=(), microphone=(), midi=(), payment=(), serial=(), usb=(), xr-spatial-tracking=()"
		Referrer-Policy no-referrer
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		-Server
	}

	# --- Code-delivery cache policy (#43 service-worker pinning) ------------------------------------------
	# Only the content-hashed assets (/assets/* and workbox-<hash>.js) are immutable — cache them for a year.
	# EVERYTHING else this origin serves must always revalidate: the HTML entry AND every SPA deep-link route
	# (/chat, /settings/…, /rooms/123, …) that the static handler's try_files rewrites to index.html, plus
	# sw.js / manifest.webmanifest / bundle-manifest.json. `header` is evaluated against the ORIGINAL request
	# path (before try_files rewrites to /index.html), so we match by EXCLUSION — anything that is not an
	# immutable asset or a proxied /api|/ws path — rather than an allowlist that would miss deep-link
	# navigations and let a stale (or tampered) app shell pin the client. `no-cache` means "revalidate"
	# (ETag 304s), not "don't store" — the SW still precaches the offline shell.
	@immutable path /assets/* /workbox-*.js
	header @immutable Cache-Control "public, max-age=31536000, immutable"
	@revalidate not path /assets/* /workbox-*.js /api/* /ws /ws/*
	header @revalidate Cache-Control "no-cache"

	# --- Admin surfaces gated by Cloudflare Access ------------------------------------------------------
	# The breakglass admin login page (/admin) and the admin/breakglass API are reachable ONLY through
	# Cloudflare Access. cloudflared injects `Cf-Access-Jwt-Assertion` on requests that passed the Access
	# policy and STRIPS any client-supplied copy, so the header's ABSENCE means the request did not pass
	# Access → return 404 (not 403: don't confirm the route exists to an unauthenticated scanner). Requests
	# that passed Access carry the header and fall through to the normal SPA/API handling below. This block is
	# FIRST among the `handle` blocks so it wins before handle_path /api/* and the static fallback. The API
	# additionally verifies the Access JWT signature (defense in depth, env-gated CfAccessGuard). Only these
	# admin paths are gated — the main app, passkey login, and end-user /api routes are unaffected. See
	# docs/threat-models/admin-access-gating.md + docs/architecture/deploy.md.
	@admin_nojwt {
		# Match the bare prefixes too (not just /*) so a future index route on the admin/breakglass
		# controllers can never be reachable un-gated at the bare path.
		path /admin /admin/* /api/auth/breakglass /api/auth/breakglass/* /api/admin /api/admin/*
		not header Cf-Access-Jwt-Assertion *
	}
	handle @admin_nojwt {
		respond 404
	}

	# --- API (REST) --------------------------------------------------------------------------------------
	# Strip the /api prefix: the API mounts its routes at the root, and the browser calls /api/* same-origin
	# (identical to the Vite dev proxy's `^/api` -> `` rewrite). e.g. /api/healthz -> upstream /healthz.
	handle_path /api/* {
		reverse_proxy api:3000
	}

	# --- Realtime gateway (WebSocket) --------------------------------------------------------------------
	# Path is preserved (the gateway mounts at /ws). Caddy detects the Upgrade and proxies the WS transparently.
	# The auth token rides the first app frame, never the URL.
	@ws path /ws /ws/*
	handle @ws {
		reverse_proxy api:3000
	}

	# --- Container healthcheck (cheap, no upstream dependency) -------------------------------------------
	handle /caddy-healthz {
		respond 200
	}

	# --- PWA static assets + SPA fallback ----------------------------------------------------------------
	# Everything else is the installable PWA; unknown paths fall back to index.html for client-side routing.
	handle {
		root * /srv
		encode zstd gzip
		try_files {path} /index.html
		file_server
	}
}
