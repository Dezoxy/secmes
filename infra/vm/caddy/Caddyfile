# argus production single-origin router.
#
# Plain HTTP on :8080 ONLY. TLS terminates at the Cloudflare edge; cloudflared dials this server over the
# internal Docker network, so Caddy never needs a public cert or :443. A non-privileged port lets Caddy run
# as a non-root user with all Linux capabilities dropped. Caddy is the single origin: it serves the PWA
# static build and reverse-proxies /api + /ws to the API. The Cloudflare tunnel ingress (dashboard-managed)
# points the public hostname at http://caddy:8080. See docs/threat-models/vm-ingress.md.
{
	# No public cert, no :443, no Let's Encrypt — the edge owns TLS.
	auto_https off
	# Admin API off: nothing on this host should reconfigure Caddy at runtime.
	admin off
	# Access log to stdout (collected by Docker). Caddy redacts Authorization + Cookie headers by default,
	# and request bodies are never logged — so logs stay IDs/metadata only (invariant #2). No URLs carry secrets.
	log {
		output stdout
		format json
	}
}

# --- Self-hosted Zitadel (OIDC issuer https://auth.4rgus.com) -------------------------------------------
# This host is matched FIRST (more specific than the catch-all :8080 app site below); cloudflared forwards
# the original Host header, so Caddy routes by it. Zitadel speaks gRPC (console + APIs) over HTTP/2, so the
# upstream is dialled h2c (HTTP/2 cleartext) — the documented Zitadel-behind-a-proxy setup. Note: NO
# X-Frame-Options here — oidc-client-ts silent-renew loads the authorize endpoint in a hidden iframe, and
# Zitadel sets its own framing/security headers. TLS terminates at Cloudflare; this stays plain HTTP on :8080.
http://auth.4rgus.com:8080 {
	# Login V2 UI is a separate container; everything else (OIDC/OAuth/JWKS/console/gRPC) is the main server.
	@login path /ui/v2/login /ui/v2/login/*
	handle @login {
		reverse_proxy zitadel-login:3000
	}
	# Zitadel's public API alias under /api/* must have the prefix STRIPPED before it reaches the server (the
	# console + Login V2 call the API via this alias). `handle_path` strips the matched prefix, mirroring the
	# canonical v4.15 compose's `zitadel-strip-api` stripprefix — e.g. /api/oauth/v2/keys -> /oauth/v2/keys.
	handle_path /api/* {
		reverse_proxy h2c://zitadel:8080
	}
	# Everything else (OIDC/OAuth/JWKS/console/gRPC at the root) → the identity server.
	handle {
		reverse_proxy h2c://zitadel:8080
	}
}

# --- App origin (PWA + /api + /ws) — catch-all :8080 for every other host (4rgus.com, health, direct IP) ---
:8080 {
	# Defense-in-depth response headers (the edge adds HSTS and more). CSP is app-managed in the PWA.
	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		X-Frame-Options DENY
		-Server
	}

	# --- API (REST) --------------------------------------------------------------------------------------
	# Strip the /api prefix: the API mounts its routes at the root, and the browser calls /api/* same-origin
	# (identical to the Vite dev proxy's `^/api` -> `` rewrite). e.g. /api/healthz -> upstream /healthz.
	handle_path /api/* {
		reverse_proxy api:3000
	}

	# --- Realtime gateway (WebSocket) --------------------------------------------------------------------
	# Path is preserved (the gateway mounts at /ws). Caddy detects the Upgrade and proxies the WS transparently.
	# The auth token rides the first app frame, never the URL.
	@ws path /ws /ws/*
	handle @ws {
		reverse_proxy api:3000
	}

	# --- Container healthcheck (cheap, no upstream dependency) -------------------------------------------
	handle /caddy-healthz {
		respond 200
	}

	# --- PWA static assets + SPA fallback ----------------------------------------------------------------
	# Everything else is the installable PWA; unknown paths fall back to index.html for client-side routing.
	handle {
		root * /srv
		encode zstd gzip
		try_files {path} /index.html
		file_server
	}
}
