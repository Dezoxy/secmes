# Project config (no tokens — auth lives in ~/.npmrc or env). gitleaks scans this file.
# pnpm >=11 only reads auth/registry settings from .npmrc — engine-strict moved to
# pnpm-workspace.yaml's "engineStrict".
# npm-ecosystem supply-chain hardening. Always a no-op for pnpm (it has no min-release-age
# .npmrc key of its own — the pnpm-native equivalent is pnpm-workspace.yaml's
# minimumReleaseAge, which is live as of the pnpm 11.9.0 upgrade). Kept here for tooling
# that assumes npm as the installer.
min-release-age=7
