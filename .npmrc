# Project config (no tokens — auth lives in ~/.npmrc or env). gitleaks scans this file.
# Fail `pnpm install` outright on an unsupported Node version instead of warning,
# so the engines.node floor (ESLint 10) is actually enforced.
engine-strict=true
# npm-ecosystem supply-chain hardening. Inert on this repo's pnpm 9.12.0 pin (that
# pnpm version has no release-age feature at all, same as pnpm-workspace.yaml's
# minimumReleaseAge) — kept for tooling that assumes npm as the installer.
min-release-age=7
