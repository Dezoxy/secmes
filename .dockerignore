# Build context hygiene for repo-root image builds (fallback). BOTH production images build from the repo
# root (cd.yml: context=.) — apps/api/Dockerfile and infra/vm/caddy/Dockerfile. Each has its OWN
# `<dockerfile>.dockerignore` (apps/api/Dockerfile.dockerignore, infra/vm/caddy/Dockerfile.dockerignore) that
# BuildKit uses INSTEAD OF this file, additionally excluding the OTHER app's source so a change to one app
# doesn't invalidate the other image's cached layers. This root file is the fallback for any other context=.
# build; keep the three in sync.

# Dependencies & build outputs — reinstalled/rebuilt inside the image.
**/node_modules
**/dist
**/build
**/.turbo
**/*.tsbuildinfo

# VCS & CI
.git
.github
.gitignore

# Secrets & local config — must NEVER enter an image layer or the build context.
# `secrets/` holds the mounted credential files (DB URL, B2 key) compose.prod.yaml delivers at runtime; a
# repo-root `COPY . .` would otherwise pull them into the daemon context + intermediate layers.
# argus-secret-excludes >>> keep this block byte-identical across all *dockerignore (CI: dockerignore-guard)
secrets/
.secrets/
**/.env
**/.env.*
**/*.tfvars
**/*.tfstate
**/*.tfstate.*
**/.terraform
*.pem
*.key
# argus-secret-excludes <<<

# Tests, coverage, reports — not needed to build the PWA.
**/coverage
**/playwright-report
**/test-results
**/*.spec.ts
**/*.test.ts
**/__tests__

# Editor / OS cruft
.vscode
.idea
**/.DS_Store

# Docs & infra not needed in the build context (keep the context small).
docs
infra/backup
infra/cleanup
infra/local
