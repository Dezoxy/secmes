# argus production configuration — TEMPLATE. Copy the non-secret values into your deploy environment.
# SECRETS are never set here and never via env_file — see the SECRETS section at the bottom.
#
# This file documents what compose.prod.yaml expects. It contains NO real values — placeholders only.
# In production these are delivered by Slice 3: Azure Key Vault → systemd credential files / runtime values,
# fetched by the VM's Managed Identity (never committed, never long-lived in env at rest). See docs/deploy.md.

# ──────────────────────────────────────────────────────────────────────────────────────────────────────
# Non-secret config (invariant #5 permits these in the environment). Set on the host / in CD.
# ──────────────────────────────────────────────────────────────────────────────────────────────────────

# Container images produced + signed by cd.yml; CD sets these to the registry digest/tag.
ARGUS_API_IMAGE=ghcr.io/dezoxy/argus-api:latest
ARGUS_INGRESS_IMAGE=ghcr.io/dezoxy/argus-ingress:latest

# Backblaze B2 (S3-compatible, EU). The access-key-ID is NOT a secret (it rides in every presigned URL);
# the matching SECRET access key IS a secret → delivered as a file (see SECRETS below).
S3_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
S3_REGION=eu-central-003
S3_BUCKET=argus-attachments
S3_ACCESS_KEY_ID=your-b2-key-id
REDIS_URL=redis://redis:6379

# OIDC for the API (runtime, non-secret issuer + audience). Wired when self-hosted Zitadel lands (roadmap #9).
OIDC_ISSUER=https://auth.4rgus.com
OIDC_AUDIENCE=your-spa-client-id

# OIDC for the PWA — BUILD-TIME (Vite embeds VITE_* into the static bundle). The Caddy image build reads
# these as build args; without VITE_OIDC_ISSUER + VITE_OIDC_CLIENT_ID the shipped client runs in demo mode
# (no real auth). Set them in CD when building the ingress image. NOT secrets.
VITE_OIDC_ISSUER=https://auth.4rgus.com
VITE_OIDC_CLIENT_ID=your-spa-client-id
VITE_OIDC_REDIRECT_URI=https://4rgus.com/auth/callback

# ──────────────────────────────────────────────────────────────────────────────────────────────────────
# SECRETS — never put values here. Delivered as FILES (invariant #5) or a runtime-fetched value:
#
#   secrets/postgres_password        → Postgres reads it via POSTGRES_PASSWORD_FILE
#   secrets/database_url             → the api reads it via DATABASE_URL_FILE
#                                       (full URL incl. password: postgres://argus:<pw>@postgres:5432/argus)
#   secrets/s3_secret_access_key     → the api reads it via S3_SECRET_ACCESS_KEY_FILE (B2 key secret)
#
#   TUNNEL_TOKEN  (the Cloudflare tunnel token you added to env.local) — the ONE secret that can't be a
#     mounted file (cloudflared has no shell / no --token-file). Injected as a RUNTIME-FETCHED value into
#     the deploy environment (Slice 3: systemd sets it from Key Vault) — never an on-disk env file.
#
# The `secrets/` directory is gitignored. In production, Slice 3 generates these files / runtime values from
# Key Vault via Managed Identity at deploy time; they are NEVER committed nor baked into an image.
# ──────────────────────────────────────────────────────────────────────────────────────────────────────
