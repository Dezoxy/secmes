# argus production configuration — TEMPLATE. Copy the non-secret values into your deploy environment and
# put the SECRET values in `secrets/argus.prod.env` + `secrets/postgres_password` (both gitignored).
#
# This file documents what compose.prod.yaml expects. It contains NO real values — placeholders only.
# In production these are delivered by Slice 3: Azure Key Vault → systemd credential files, fetched by the
# VM's Managed Identity (never committed, never long-lived in env at rest). See docs/deploy.md.

# ──────────────────────────────────────────────────────────────────────────────────────────────────────
# Non-secret config (invariant #5 permits these in the environment). Set on the host / in CD.
# ──────────────────────────────────────────────────────────────────────────────────────────────────────

# Container images produced + signed by cd.yml; CD sets these to the registry digest/tag.
ARGUS_API_IMAGE=ghcr.io/dezoxy/argus-api:latest
ARGUS_INGRESS_IMAGE=ghcr.io/dezoxy/argus-ingress:latest

# Backblaze B2 (S3-compatible, EU). The access-key-ID is NOT a secret (it rides in every presigned URL);
# the matching SECRET access key IS a secret → secrets/argus.prod.env (below).
S3_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
S3_REGION=eu-central-003
S3_BUCKET=argus-attachments
S3_ACCESS_KEY_ID=your-b2-key-id

# OIDC (non-secret issuer + audience). Wired when self-hosted Zitadel joins the stack (roadmap #9).
OIDC_ISSUER=https://auth.4rgus.com
OIDC_AUDIENCE=your-spa-client-id

# ──────────────────────────────────────────────────────────────────────────────────────────────────────
# SECRETS — do NOT put these here. They live in gitignored files, populated out-of-band:
#
#   secrets/postgres_password         single line: the Postgres password (read by postgres via
#                                     POSTGRES_PASSWORD_FILE, and embedded in the api's DATABASE_URL)
#
#   secrets/argus.prod.env            KEY=VALUE lines, loaded into the api + cloudflared containers:
#     DATABASE_URL=postgres://argus:<password>@postgres:5432/argus
#     S3_SECRET_ACCESS_KEY=<b2-application-key-secret>
#     TUNNEL_TOKEN=<cloudflare-tunnel-token>          # the token you added to env.local
#
# In production, Slice 3 generates these files from Key Vault via Managed Identity at deploy time and
# removes them after the stack reads them — they are NEVER committed and NEVER baked into an image.
# ──────────────────────────────────────────────────────────────────────────────────────────────────────
