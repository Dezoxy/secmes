# argus production configuration — TEMPLATE. Copy the non-secret values into your deploy environment.
# SECRETS are never set here and never via env_file — see the SECRETS section at the bottom.
#
# This file documents what compose.prod.yaml expects. It contains NO real values — placeholders only.
# In production these are delivered by Slice 3: Azure Key Vault → systemd credential files / runtime values,
# fetched by the VM's Managed Identity (never committed, never long-lived in env at rest). See docs/deploy.md.

# ──────────────────────────────────────────────────────────────────────────────────────────────────────
# Non-secret config (invariant #5 permits these in the environment). Set on the host / in CD.
# ──────────────────────────────────────────────────────────────────────────────────────────────────────

# Container images produced + signed by cd.yml; CD sets these to the registry digest/tag.
ARGUS_API_IMAGE=ghcr.io/dezoxy/argus-api:latest
ARGUS_INGRESS_IMAGE=ghcr.io/dezoxy/argus-ingress:latest

# Backblaze B2 (S3-compatible, EU). The access-key-ID is NOT a secret (it rides in every presigned URL);
# the matching SECRET access key IS a secret → delivered as a file (see SECRETS below).
S3_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
S3_REGION=eu-central-003
S3_BUCKET=argus-attachments
S3_ACCESS_KEY_ID=your-b2-key-id
# REDIS_URL: NOT used in PROD — redis requires AUTH, so deploy.sh generates a password-bearing
# `redis://:<redis_password>@redis:6379` into a tmpfs Docker-secret FILE and the api reads it via
# REDIS_URL_FILE (the password never lands in env / `docker inspect`). The line below is only the
# local/unauthenticated fallback default for the dev stack.
REDIS_URL=redis://redis:6379

# Auth is passkey-only — the API mints/verifies its own EdDSA session tokens (no OIDC/IdP env). The signing
# key is delivered from Key Vault as a file (SESSION_SIGNING_KEY_FILE=/run/secrets/session_signing_key).
# WebAuthn RP config (FRONTEND_ORIGIN, WEBAUTHN_RP_ID, WEBAUTHN_RP_NAME) has sensible defaults in
# compose.prod.yaml; override only if the deployment domain differs from 4rgus.com.

# Error tracking (#48 Slice B) — DSN-GATED. Leave UNSET (default) and error tracking is a complete no-op.
# At arming: GlitchTip runs at https://glitchtip.4rgus.com (Cloudflare Access gated). Create a GlitchTip
# org + project, copy the DSN, store it in Key Vault as `argus-sentry-dsn` (OPTIONAL — the fetch script
# seeds an empty file on first boot). SENTRY_RELEASE defaults to IMAGE_TAG.
# Events are DEFAULT-DENY scrubbed: no message content, keys, tokens, auth headers, cookies, query, or
# presigned URLs ever leave (invariant #2; docs/threat-models/error-tracking.md).
# The DSN is delivered as a mounted file (SENTRY_DSN_FILE=/run/secrets/sentry_dsn) — never plain env.
# GLITCHTIP_DOMAIN is a non-secret env var that GlitchTip needs for constructing absolute URLs.
GLITCHTIP_DOMAIN=https://glitchtip.4rgus.com

# Cloudflare Access for the admin/breakglass surface — NON-SECRET (both values are public, like the RP ID).
# The admin login lives at https://4rgus.com/admin and the /api/auth/breakglass/* + /api/admin/* endpoints
# are gated by a Cloudflare Access self-hosted application (dashboard-managed; see docs/deploy.md). Caddy 404s
# those paths at the edge without the Access header; when BOTH vars below are set the API ALSO verifies the
# Cf-Access-Jwt-Assertion signature (defense in depth). Leave UNSET until the Access app exists (no-op).
#   CF_ACCESS_TEAM_DOMAIN — your Zero Trust team (e.g. "acme" or "acme.cloudflareaccess.com")
#   CF_ACCESS_AUD         — the Access application's Audience (AUD) tag, shown in the dashboard after creation
# CF_ACCESS_TEAM_DOMAIN=acme.cloudflareaccess.com
# CF_ACCESS_AUD=your-access-app-aud-tag

# ──────────────────────────────────────────────────────────────────────────────────────────────────────
# SECRETS — never put values here. Delivered as FILES (invariant #5) or a runtime-fetched value:
#
#   secrets/postgres_password        → Postgres reads it via POSTGRES_PASSWORD_FILE
#   secrets/database_url             → the api reads it via DATABASE_URL_FILE. MUST use the non-bypass
#                                       RUNTIME role argus_app (NOT the argus owner), so RLS/grants bind even
#                                       on a missed SET-LOCAL-ROLE path or app compromise:
#                                         postgres://argus_app:<argus_app-pw>@postgres:5432/argus
#                                       Slice 3 grants argus_app LOGIN + a Key Vault password out-of-band
#                                       (see migration 0001). The argus owner credential stays SEPARATE,
#                                       used only for init + migrations (Slice 4: MIGRATION_DATABASE_URL).
#   secrets/s3_secret_access_key     → the api reads it via S3_SECRET_ACCESS_KEY_FILE (B2 key secret)
#   secrets/redis_password           → deploy.sh generates redis.conf (requirepass) + redis_url
#                                       (redis://:<pw>@redis:6379) from it; api reads REDIS_URL_FILE, redis's
#                                       healthcheck reads this file directly. No Redis creds in env. URL-safe
#                                       (e.g. openssl rand -hex 32).
#   secrets/session_signing_key      → the api reads it via SESSION_SIGNING_KEY_FILE (Ed25519 PKCS8 PEM used
#                                       to sign passkey session JWTs). Generate ONCE:
#                                       openssl genpkey -algorithm ed25519 | openssl pkcs8 -topk8 -nocrypt -outform PEM
#   secrets/grafana_admin_password   → grafana reads it via GF_SECURITY_ADMIN_PASSWORD__FILE (observability
#                                       #47). Set it in Key Vault before the first deploy.
#   secrets/glitchtip_db_password    → glitchtip-db reads it via POSTGRES_PASSWORD_FILE; deploy.sh derives
#                                       glitchtip_database_url (postgresql://glitchtip:<pw>@glitchtip-db:5432/glitchtip)
#                                       from it (same pattern as redis_url). Set before first deploy.
#   secrets/glitchtip_secret_key     → GlitchTip Django SECRET_KEY (cryptographic, 50+ random chars).
#                                       Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
#   secrets/sentry_dsn               → GlitchTip project DSN (write-only ingest key). OPTIONAL — fetched
#                                       from Key Vault (argus-sentry-dsn); seeded EMPTY on first boot (an
#                                       optional secret). api reads it via SENTRY_DSN_FILE. Provision AFTER
#                                       first arming: GlitchTip UI → create org + project → copy DSN →
#                                       store as argus-sentry-dsn in Key Vault → redeploy.
#
#   TUNNEL_TOKEN  (the Cloudflare tunnel token you added to env.local) — the ONE secret that can't be a
#     mounted file (cloudflared has no shell / no --token-file). Injected as a RUNTIME-FETCHED value into
#     the deploy environment (Slice 3: systemd sets it from Key Vault) — never an on-disk env file.
#
# The `secrets/` directory is gitignored. In production, Slice 3 generates these files / runtime values from
# Key Vault via Managed Identity at deploy time; they are NEVER committed nor baked into an image.
# ──────────────────────────────────────────────────────────────────────────────────────────────────────
