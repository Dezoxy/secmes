{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opusplan",
  "effortLevel": "high",
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write",

      "Bash(pnpm *)",
      "Bash(node *)",

      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git --no-pager *)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git merge*)",
      "Bash(git stash*)",
      "Bash(git rev-parse*)",
      "Bash(git remote*)",
      "Bash(git rm *)",
      "Bash(git cherry-pick *)",
      "Bash(git reset *)",

      "Bash(gh pr *)",
      "Bash(gh run *)",
      "Bash(gh api *)",
      "Bash(./scripts/codex-review-status.sh *)",

      "Bash(docker compose *)",

      "Bash(terraform fmt*)",
      "Bash(terraform -chdir=* fmt*)",
      "Bash(terraform validate*)",
      "Bash(terraform -chdir=* validate*)",
      "Bash(terraform plan*)",
      "Bash(terraform -chdir=* plan*)",
      "Bash(terraform init*)",

      "Bash(semgrep*)",
      "Bash(.venv/bin/semgrep *)",
      "Bash(trivy*)",
      "Bash(gitleaks*)",
      "Bash(osv-scanner*)",
      "Bash(shellcheck *)",
      "Bash(actionlint *)",
      "Bash(bash -n *)",

      "Bash($HOME/.42crunch/bin/42c-ast *)",
      "Bash(/Users/horvathtoom/.42crunch/bin/42c-ast *)",

      "Bash(find *)",
      "Bash(ls *)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(cut *)",
      "Bash(uniq *)",
      "Bash(test *)",
      "Bash(mkdir *)",
      "Bash(rm -f *)",
      "Bash(curl *)",
      "Bash(python3 *)",
      "Bash(until *)",
      "Bash(wait)",
      "Bash(set +e)",

      "Bash(DATABASE_URL=* pnpm*)",
      "Bash(DATABASE_URL=* REDIS_URL=* pnpm*)"
    ],
    "ask": [
      "Bash(terraform apply*)",
      "Bash(terraform -chdir=* apply*)",
      "Bash(docker push*)",
      "Bash(gh pr merge*)"
    ],
    "deny": [
      "Bash(terraform destroy*)",
      "Bash(terraform -chdir=* destroy*)",
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Read(./.env)",
      "Read(./**/.env)",
      "Read(./**/*.tfvars)",
      "Edit(./.env)",
      "Edit(./**/.env)",
      "Edit(./**/*.tfvars)",
      "Write(./.env)",
      "Write(./**/.env)",
      "Write(./**/*.tfvars)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-bash.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-ts.sh\"",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-iac.sh\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/api-spec-reminder.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
