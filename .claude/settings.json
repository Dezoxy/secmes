{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opusplan",
  "effortLevel": "high",
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write",
      "Bash(pnpm *)",
      "Bash(npx playwright*)",
      "Bash(terraform fmt*)",
      "Bash(terraform -chdir=* fmt*)",
      "Bash(terraform validate*)",
      "Bash(terraform -chdir=* validate*)",
      "Bash(terraform plan*)",
      "Bash(terraform -chdir=* plan*)",
      "Bash(terraform init*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git merge*)",
      "Bash(git stash*)",
      "Bash(git rev-parse*)",
      "Bash(git remote*)",
      "Bash(docker compose up*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs*)",
      "Bash(docker compose build*)",
      "Bash(semgrep*)",
      "Bash(trivy*)",
      "Bash(gitleaks*)",
      "Bash(osv-scanner*)"
    ],
    "ask": ["Bash(terraform apply*)", "Bash(terraform -chdir=* apply*)", "Bash(docker push*)"],
    "deny": [
      "Bash(terraform destroy*)",
      "Bash(terraform -chdir=* destroy*)",
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Read(./.env)",
      "Read(./**/.env)",
      "Read(./**/*.tfvars)",
      "Edit(./.env)",
      "Edit(./**/.env)",
      "Edit(./**/*.tfvars)",
      "Write(./.env)",
      "Write(./**/.env)",
      "Write(./**/*.tfvars)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-bash.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-ts.sh\"",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-iac.sh\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/api-spec-reminder.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
