    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/platform-ws": "^11",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11",
    "@sentry/node": "^10.58.0",
    "@simplewebauthn/server": "^13.3.1",
    "cookie-parser": "^1.4.7",
