    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/platform-ws": "^11",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11",
    "@sentry/node": "^10.57.0",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
