# For LOCAL dev you normally don't touch this: `make up` generates apps/web/.env.local with the
# right values (see docs/local-auth.md). Shown below are the local Zitadel defaults. The SPA is a
# public client — no secret. For a non-local deployment, copy to .env.local and set your issuer/client.
VITE_OIDC_ISSUER=http://zitadel:8080
VITE_OIDC_CLIENT_ID=generated-by-make-up
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
# Web Push (roadmap #40). Generate a VAPID key pair with: npx web-push generate-vapid-keys
# The PUBLIC key is non-secret (embedded in the PWA). The private key goes in Key Vault → credential file
# (VAPID_PRIVATE_KEY_FILE on the server). Omit both to disable push (the feature degrades gracefully).
VITE_VAPID_PUBLIC_KEY=
